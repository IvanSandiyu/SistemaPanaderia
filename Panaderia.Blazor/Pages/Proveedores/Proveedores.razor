@page "/proveedores"
@using Panaderia.Blazor.Services
@using Panaderia.Shared.DTOs.Proveedores

@inject ProveedorService ProveedorService

<h3>Proveedores</h3>

<div class="row">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>
                <i class="bi bi-truck me-2"></i>
                Gestión de Proveedores
            </h2>

            <small class="text-muted">
                Administración de proveedores registrados
            </small>

        </div>

        <button class="btn btn-success"
                @onclick="NuevoProveedor">

            <i class="bi bi-plus-circle me-2"></i>
            Nuevo Proveedor

        </button>

    </div>


    <div class="col-12">

        <div class="card shadow-sm">

            <div class="card-header">

                <div class="d-flex justify-content-between align-items-center">

                    <h5 class="mb-0">

                        <i class="bi bi-truck me-2"></i>

                        Proveedores

                    </h5>

                    <input class="form-control form-control-sm"
                           style="width:220px"
                           placeholder="🔎 Buscar proveedor..."
                           @bind="Busqueda"
                           @bind:event="oninput" />

                </div>

            </div>


            <div class="card-body p-0">

                <table class="table table-hover table-striped mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>Proveedor</th>
                            <th>CUIT</th>
                            <th>Teléfono</th>
                            <th>Email</th>
                            <th>Dirección</th>
                            <th>Estado</th>
                            <th style="width:160px">Acciones</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var proveedor in ProveedoresFiltrados) {
                            <tr>

                                <td>

                                    <strong>@proveedor.Nombre</strong>

                                </td>

                                <td>

                                    @proveedor.Cuit

                                </td>

                                <td>

                                    @proveedor.Telefono

                                </td>

                                <td>

                                    @proveedor.Email

                                </td>

                                <td>

                                    @proveedor.Direccion

                                </td>

                                <td>

                                    @if (proveedor.Activo) {
                                        <span class="badge bg-success">

                                            Activo

                                        </span>
                                    } else {
                                        <span class="badge bg-danger">

                                            Inactivo

                                        </span>
                                    }

                                </td>

                                <td>

                                    <div class="btn-group btn-group-sm">

                                        <button class="btn btn-outline-primary"
                                                title="Editar"
                                                @onclick="() => Editar(proveedor.Id)">

                                            <i class="bi bi-pencil"></i>

                                        </button>

                                        <button class="btn btn-outline-danger"
                                                title="Eliminar"
                                                @onclick="() => Eliminar(proveedor.Id)">

                                            <i class="bi bi-trash"></i>

                                        </button>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

@code {

    private string Busqueda = "";

    private List<ProveedorDTO> proveedores = new();

    private IEnumerable<ProveedorDTO> ProveedoresFiltrados =>
        string.IsNullOrWhiteSpace(Busqueda)
            ? proveedores
            : proveedores.Where(x =>
                x.Nombre.Contains(Busqueda,
                StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        proveedores = await ProveedorService.ObtenerTodos();
    }

    private void NuevoProveedor()
    {
        //Navigation.NavigateTo("/proveedores/nuevo");
    }

    private void Editar(int id)
    {
        //Navigation.NavigateTo($"/proveedores/editar/{id}");
    }

    private async Task Eliminar(int id)
    {
        // eliminar
    }

}
@page "/proveedores"
@inject NavigationManager Navigation
@using Panaderia.Blazor.Services
@using Panaderia.Shared.DTOs.Proveedores

@inject ProveedorService ProveedorService

<h3>Proveedores</h3>

<div class="row">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>
                <i class="bi bi-truck me-2"></i>
                Gestión de Proveedores
            </h2>

            <small class="text-muted">
                Administración de proveedores registrados
            </small>

        </div>

        <button class="btn btn-success"
                @onclick="NuevoProveedor">

            <i class="bi bi-plus-circle me-2"></i>
            Nuevo Proveedor

        </button>

    </div>

    <div class="col-12">

        <div class="card shadow-sm">

            <div class="card-header">

                <div class="d-flex justify-content-between align-items-center">

                    <h5 class="mb-0">

                        <i class="bi bi-truck me-2"></i>

                        Proveedores

                    </h5>

                    <input class="form-control form-control-sm"
                           style="width:220px"
                           placeholder="🔎 Buscar proveedor..."
                           @bind="Busqueda"
                           @bind:event="oninput" />

                </div>

            </div>

            @if (Cargando) {
                <div class="card-body">

                    <div class="text-center py-5">

                        <div class="spinner-border text-primary"></div>

                        <p class="mt-3 text-muted">
                            Cargando proveedores...
                        </p>

                    </div>

                </div>
            } else if (!ProveedoresFiltrados.Any()) {
                <div class="card-body">

                    <div class="text-center py-5 text-muted">

                        <i class="bi bi-inbox display-4"></i>

                        <h5 class="mt-3">
                            No se encontraron proveedores
                        </h5>

                        <p>
                            Intente con otro criterio de búsqueda o agregue un nuevo proveedor.
                        </p>

                    </div>

                </div>
            } else {
                <div class="table-responsive">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">

                            <tr>

                                <th>Proveedor</th>
                                <th>CUIT</th>
                                <th>Contacto</th>
                                <th>Dirección</th>
                                <th>Estado</th>
                                <th class="text-center" style="width:140px">
                                    Acciones
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var proveedor in ProveedoresFiltrados) {
                                <tr>

                                    <td>

                                        <strong>
                                            @proveedor.Nombre
                                        </strong>

                                    </td>

                                    <td>

                                        @proveedor.Cuit

                                    </td>

                                    <td>

                                        <div>

                                            <i class="bi bi-telephone me-2"></i>

                                            @proveedor.Telefono

                                        </div>

                                        <small class="text-muted">

                                            <i class="bi bi-envelope me-2"></i>

                                            @proveedor.Email

                                        </small>

                                    </td>

                                    <td>

                                        @proveedor.Direccion

                                    </td>

                                    <td>

                                        @if (proveedor.Activo) {
                                            <span class="badge bg-success">
                                                Activo
                                            </span>
                                        } else {
                                            <span class="badge bg-danger">
                                                Inactivo
                                            </span>
                                        }

                                    </td>

                                    <td class="text-center">

                                        <div class="btn-group btn-group-sm">

                                            <button class="btn btn-outline-primary"
                                                    title="Editar"
                                                    @onclick="() => Editar(proveedor.Id)">

                                                <i class="bi bi-pencil"></i>

                                            </button>

                                            <button class="btn btn-outline-danger"
                                                    title="Eliminar"
                                                    @onclick="() => Eliminar(proveedor.Id)">

                                                <i class="bi bi-trash"></i>

                                            </button>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>

    </div>

</div>

@code {

    private string Busqueda = "";

    private List<ProveedorDTO> proveedores = new();
    private bool Cargando = true;

    private IEnumerable<ProveedorDTO> ProveedoresFiltrados =>
        string.IsNullOrWhiteSpace(Busqueda)
            ? proveedores
            : proveedores.Where(x =>
                x.Nombre.Contains(Busqueda,
                StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        Cargando = true;
        proveedores = await ProveedorService.ObtenerTodos();
        Cargando = false;
    }

    private void NuevoProveedor()
    {
        Navigation.NavigateTo("/proveedores/nuevo");
    }

    private void Editar(int id)
    {
        Navigation.NavigateTo($"/proveedores/editar/{id}");
    }

    private async Task Eliminar(int id)
    {
        // eliminar
    }

}
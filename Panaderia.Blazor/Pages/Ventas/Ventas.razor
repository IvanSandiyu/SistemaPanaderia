@page "/ventas"
@using Panaderia.Blazor.Models
@using Panaderia.Blazor.Models.Productos
@using Panaderia.Blazor.Models.Ventas
@using Panaderia.Blazor.Services

@inject ProductoService ProductoService
@inject VentaService VentaService

<h3>Ventas</h3>

<div class="row">
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2>
                <i class="bi bi-cart-check-fill me-2"></i>
                Nueva Venta
            </h2>

            <small class="text-muted">
                Registrar venta y actualizar stock
            </small>
        </div>

    </div>

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-box-seam-fill me-2"></i>
                    Productos
                </h5>
            </div>

            <div class="card-body p-0">

                <table class="table table-hover mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var producto in Productos) {
                            <tr>

                                <td>
                                    <strong>@producto.Nombre</strong>
                                </td>

                                <td>
                                    $ @producto.PrecioVenta
                                </td>

                                <td>

                                    @if (producto.StockActual == 0) {
                                        <span class="badge bg-danger">
                                            Sin stock
                                        </span>
                                    } else if (producto.StockActual <= 10) {
                                        <span class="badge bg-warning text-dark">
                                            @producto.StockActual
                                        </span>
                                    } else {
                                        <span class="badge bg-success">
                                            @producto.StockActual
                                        </span>
                                    }

                                </td>

                                <td>

                                    <button class="btn btn-success btn-sm me-1"
                                            disabled="@(!PuedeAgregar(producto))"
                                            @onclick="() => AgregarAlCarrito(producto)">

                                        <i class="bi bi-plus-lg"></i>

                                    </button>

                                    <button class="btn btn-danger btn-sm"
                                            @onclick="() => EliminarDelCarrito(producto.Id)">

                                        <i class="bi bi-dash-lg"></i>

                                    </button>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
    <div class="col-lg-4">

        <div class="card shadow-sm sticky-top">

            <div class="card-header bg-primary text-white">

                <h5 class="mb-0">
                    <i class="bi bi-cart-fill me-2"></i>
                    Carrito
                </h5>

            </div>

            <div class="card-body">

                @if (!Carrito.Any()) {
                    <div class="text-center text-muted py-4">

                        <i class="bi bi-cart-x display-5"></i>

                        <p class="mt-3">
                            No hay productos agregados
                        </p>

                    </div>
                } else {
                    <table class="table">

                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Cant.</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Carrito) {
                                <tr>

                                    <td>@item.Nombre</td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @item.Cantidad
                                        </span>
                                    </td>

                                    <td>
                                        $ @(item.Cantidad* item.PrecioVenta)
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                    <hr />

                    <div class="text-center">

                        <h3 class="text-success">
                            $ @Total
                        </h3>

                        <small class="text-muted">
                            Total a cobrar
                        </small>

                    </div>

                    <button class="btn btn-success btn-lg w-100 mt-3"
                            @onclick="AbrirModalPago">

                        <i class="bi bi-cash-stack me-2"></i>
                        Cobrar

                    </button>
                }

            </div>

        </div>

    </div>

    @if (MostrarModalPago) {
        <div class="modal fade show d-block"
             tabindex="-1"
             style="background-color: rgba(0,0,0,0.5);">

            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Método de Pago</h5>

                        <button type="button"
                                class="btn-close"
                                @onclick="CerrarModal">
                        </button>
                    </div>

                    <div class="modal-body">

                        <div class="mb-3">
                            <label class="form-label">
                                Método de Pago
                            </label>

                            <InputSelect class="form-select"
                                         @bind-Value="MetodoPago">

                                <option>Efectivo</option>
                                <option>Transferencia</option>
                                <option>Fiado</option>
                                <option>Regalo</option>

                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Observaciones
                            </label>

                            <InputTextArea class="form-control"
                                           rows="3"
                                           @bind-Value="Observaciones" />
                        </div>

                    </div>

                    <div class="modal-footer">

                        <button class="btn btn-secondary"
                                @onclick="CerrarModal">
                            Cancelar
                        </button>

                        <button class="btn btn-success"
                                @onclick="RealizarPago">

                            <i class="bi bi-check-circle me-2"></i>
                            Confirmar Venta

                        </button>

                    </div>

                </div>
            </div>
        </div>
    }


</div>

@code {

    private List<ProductoDto> Productos = new();

    private List<CarritoItemDto> Carrito = new();
    private bool MostrarModalPago = false;

    private string MetodoPago = "Efectivo";

    private string Observaciones = "";

    private decimal Total =>
        Carrito.Sum(x => x.Cantidad * x.PrecioVenta);

    protected override async Task OnInitializedAsync()
    {
        Productos = await ProductoService.ObtenerTodos();
    }

    private void AgregarAlCarrito(ProductoDto producto)
    {
        var item = Carrito.FirstOrDefault(x => x.Id == producto.Id);

        if (item is null) {
            Carrito.Add(new CarritoItemDto
            {
                Id = producto.Id,
                Nombre = producto.Nombre,
                PrecioVenta = producto.PrecioVenta,
                Cantidad = 1
            });
        } else {
            item.Cantidad++;
        }
    }
    private void EliminarDelCarrito(int id)
    {
        var item = Carrito.FirstOrDefault(x => x.Id == id);
        if(item is not null){
            Carrito.Remove(item);
            item.Cantidad--;
        }
    }

    private async Task RealizarPago()
    {
        var venta = new VentaDto
        {
            MetodoPago = MetodoPago,
            Observaciones = Observaciones,

            Detalles = Carrito.Select(x => new DetalleVentaDto
            {
                ProductoId = x.Id,
                Cantidad = x.Cantidad
            }).ToList()
        };

        var resultado = await VentaService.RealizarVenta(venta);

        if (resultado) {
            Carrito.Clear();
            Productos = await ProductoService.ObtenerTodos();
            MostrarModalPago = false;
        }
    }
    private bool PuedeAgregar(ProductoDto producto)
    {
        var item = Carrito.FirstOrDefault(x => x.Id== producto.Id);

        if (item is null)
            return producto.StockActual > 0;

        return item.Cantidad < producto.StockActual;
    }

    private void AbrirModalPago()
    {
        MostrarModalPago = true;
    }
    private void CerrarModal()
    {
        MostrarModalPago = false;
    }

}
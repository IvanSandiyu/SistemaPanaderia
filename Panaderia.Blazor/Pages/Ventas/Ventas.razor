@page "/ventas"
@using Panaderia.Blazor.Models
@using Panaderia.Shared.DTOs.Productos
@using Panaderia.Shared.DTOs.Reportes
@using Panaderia.Shared.DTOs.Ventas
@using Panaderia.Blazor.Services
@using Panaderia.Shared.Enums

@inject ProductoService ProductoService
@inject VentaService VentaService
@inject IJSRuntime JS
@inject ReporteService ReporteService

<h3>Ventas</h3>

<div class="row">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2 class="mb-0">
                <i class="bi bi-cart-check-fill me-2"></i>
                Nueva Venta
            </h2>

            <small class="text-muted">
                Registrar venta y actualizar stock
            </small>

        </div>

        <button class="btn btn-outline-success"
                @onclick="ExportarVentasHoy">

            <i class="bi bi-file-earmark-arrow-down me-2"></i>
            Ventas del día

        </button>

    </div>  

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header">

                <div class="d-flex justify-content-between align-items-center">

                    <h5 class="mb-0">

                        <i class="bi bi-box-seam-fill me-2"></i>

                        Productos

                    </h5>

                    <div style="width:300px">

                        <input class="form-control form-control-sm"
                               placeholder="🔎 Buscar producto..."
                               @bind="Busqueda"
                               @bind:event="oninput" />

                    </div>

                </div>

            </div>

            <div class="card-body p-0"
                 style="max-height:650px;overflow-y:auto;">

                <table class="table table-hover table-sm mb-0">

                    <thead class="table-light sticky-top">

                        <tr>

                            <th>Producto</th>

                            <th>Precio</th>

                            <th>Stock</th>

                            <th style="width:230px">

                                Acciones

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var producto in ProductosFiltrados) {

                            <tr>

                                <td>

                                    <strong>

                                        @producto.Nombre

                                    </strong>

                                </td>


                                <td>

                                    @if (producto.PrecioVentaUnidad.HasValue) {
                                        <small class="d-block">

                                            U:
                                            $@producto.PrecioVentaUnidad

                                        </small>
                                    }

                                    @if (producto.PrecioVenta > 0) {
                                        <small class="d-block">

                                            Kg:
                                            $@producto.PrecioVenta

                                        </small>
                                    }

                                </td>


                                <td>

                                    @if (producto.StockActual == 0) {
                                        <span class="badge bg-danger">

                                            0

                                        </span>
                                    } else if (producto.StockActual <= 10) {
                                        <span class="badge bg-warning text-dark">

                                            @producto.StockActual

                                        </span>
                                    } else {
                                        <span class="badge bg-success">

                                            @producto.StockActual

                                        </span>
                                    }

                                </td>

                                <td>

                                    <div class="d-flex gap-1 flex-wrap">

                                        @if (producto.PrecioVentaUnidad.HasValue) {
                                            <button class="btn btn-success btn-sm"
                                                    title="Unidad"
                                                    @onclick="() => AgregarAlCarrito(producto)">

                                                U

                                            </button>
                                        }


                                        @if (producto.PrecioVenta > 0) {

                                            <button class="btn btn-outline-primary btn-sm"
                                                    title="1/4 Kg"
                                                    @onclick="() => AgregarPorKg(producto, 0.25m)">

                                                ¼

                                            </button>


                                            <button class="btn btn-outline-primary btn-sm"
                                                    title="1/2 Kg"
                                                    @onclick="() => AgregarPorKg(producto, 0.50m)">

                                                ½

                                            </button>


                                            <button class="btn btn-outline-primary btn-sm"
                                                    title="1 Kg"
                                                    @onclick="() => AgregarPorKg(producto, 1m)">

                                                1

                                            </button>

                                        }

                                    </div>


                                    @if (producto.PrecioVenta > 0) {

                                        <div class="mt-1 d-flex">

                                            <input type="number"
                                                   class="form-control form-control-sm"
                                                   placeholder="$"
                                                   value="@Montos.GetValueOrDefault(producto.Id)"
                                                   @oninput="e => Montos[producto.Id] =
                                                   decimal.TryParse(
                                                   e.Value?.ToString(),
                                                   out var v)
                                                   ? v : 0" />



                                    <button class="btn btn-warning btn-sm ms-1"
                                            @onclick="() =>

                                                                                            AgregarPorMonto(

                                                                                            producto,

                                                                                            Montos.GetValueOrDefault(

                                                                                            producto.Id))">

                                        $

                                            </button>

                                        </div>

                                                                }

                                </td>

                            </tr>

                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
    <div class="col-lg-4">

        <div class="card shadow-sm sticky-top">

            <div class="card-header bg-primary text-white">

                <h5 class="mb-0">
                    <i class="bi bi-cart-fill me-2"></i>
                    Carrito
                </h5>

            </div>

            <div class="card-body">

                @if (!Carrito.Any()) {
                    <div class="text-center text-muted py-4">

                        <i class="bi bi-cart-x display-5"></i>

                        <p class="mt-3">
                            No hay productos agregados
                        </p>

                    </div>
                } else {
                    <table class="table">

                        <thead>
                            <tr>
                                <th>Producto</th>
                                <th>Cant.</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Carrito) {
                                <tr>

                                    <td>@item.Nombre</td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @item.Cantidad?.ToString("N3")
                                        </span>
                                    </td>

                                    <td>
                                        @* $ @((item.Cantidad * item.PrecioUnitario)?.ToString("N2")) *@
                                        $ @item.Subtotal?.ToString("N2")
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                    <hr />

                    <div class="text-center">

                        <h3 class="text-success">
                            $ @Total
                        </h3>

                        <small class="text-muted">
                            Total a cobrar
                        </small>

                    </div>

                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">

                        <h5 class="mb-0">
                            <i class="bi bi-cart-fill me-2"></i>
                            Carrito
                        </h5>

                        <button class="btn btn-sm btn-light"
                                @onclick="LimpiarCarrito">

                            <i class="bi bi-trash"></i>
                        </button>
                        <button class="btn btn-sm btn-light"
                                @onclick="AbrirModalPago">

                            <i class="bi bi-currency-dollar"></i>
                        </button>

                    </div>
                }

            </div>

        </div>

    </div>
    <div class="d-flex justify-content-center align-items-center gap-2 mt-3">

        <button class="btn btn-outline-primary btn-sm"
                disabled="@(PaginaActual == 1)"
                @onclick="PaginaAnterior">

            <i class="bi bi-chevron-left"></i>

        </button>

        <span class="badge bg-primary fs-6 px-3 py-2">
            @PaginaActual
        </span>

        <button class="btn btn-outline-primary btn-sm"
                @onclick="SiguientePagina">
            <i class="bi bi-chevron-right"></i>

        </button>

    </div>

    @if (MostrarModalPago) {
        <div class="modal fade show d-block"
             tabindex="-1"
             style="background-color: rgba(0,0,0,0.5);">

            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Método de Pago</h5>

                        <button type="button"
                                class="btn-close"
                                @onclick="CerrarModal">
                        </button>
                    </div>

                    <div class="modal-body">

                        <div class="mb-3">
                            <label class="form-label">
                                Método de Pago
                            </label>

                            <InputSelect class="form-select"
                                         @bind-Value="MetodoPagoSeleccionado">
                                @foreach (var item in Enum.GetValues<MetodoDePago>()) {
                                    <option value="@item">@item</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Observaciones
                            </label>

                            <InputTextArea class="form-control"
                                           rows="3"
                                           @bind-Value="Observaciones" />
                        </div>

                    </div>

                    <div class="modal-footer">

                        <button class="btn btn-secondary"
                                @onclick="CerrarModal">
                            Cancelar
                        </button>

                        <button class="btn btn-success"
                                @onclick="RealizarPago">

                            <i class="bi bi-check-circle me-2"></i>
                            Confirmar Venta

                        </button>

                    </div>

                </div>
            </div>
        </div>
    }


</div>

@code {
    private Dictionary<int, decimal> Montos = new();
    private List<ProductoDTO> Productos = new();

    private List<CarritoItemDto> Carrito = new();
    private bool MostrarModalPago = false;

    private string Observaciones = "";

    private decimal? Total => Carrito.Sum(x => x.Subtotal);

    protected override async Task OnInitializedAsync()
    {
        Productos = await ProductoService.ObtenerTodos();
        foreach (var producto in Productos) {
            Montos[producto.Id] = 0;
        }
    }
    private string Busqueda = "";

    private IEnumerable<ProductoDTO> ProductosFiltrados =>
        string.IsNullOrWhiteSpace(Busqueda)
            ? Productos
            : Productos.Where(x =>
                x.Nombre.Contains(
                    Busqueda,
                    StringComparison.OrdinalIgnoreCase));

    private void AgregarAlCarrito(ProductoDTO producto)
    {
        //var item = Carrito.FirstOrDefault(x => x.Id == producto.Id);
        var item = Carrito.FirstOrDefault(x => x.Id == producto.Id && x.TipoVenta == TipoVenta.Unidad);

        if (item is null) {
            Carrito.Add(new CarritoItemDto
            {
                Id = producto.Id,
                Nombre = producto.Nombre,
                PrecioUnitario = producto.PrecioVentaUnidad ?? 0,
                PrecioAplicado = producto.PrecioVentaUnidad.Value ,
                Cantidad = 1,
                TipoVenta = TipoVenta.Unidad
            });

        } else {
            item.Cantidad++;
        }
    }

    private void AgregarPorMonto(ProductoDTO producto, decimal montoIngresado)
    {
        if (montoIngresado <= 0)
            return;

        decimal? cantidadKg = Math.Round(montoIngresado / producto.PrecioVenta.Value,2);

        var item = Carrito.FirstOrDefault(x => x.Id == producto.Id && x.TipoVenta == TipoVenta.Monto);

        if (item is null) {
            Carrito.Add(new CarritoItemDto {
                Id = producto.Id,
                Nombre = producto.Nombre,
                Cantidad = cantidadKg,
                PrecioAplicado = producto.PrecioVenta.Value,
                TipoVenta = TipoVenta.Monto
            });
        } else {
            item.Cantidad += cantidadKg;
        }

        Montos[producto.Id] = 0;
    }

    private void AgregarPorKg(ProductoDTO producto, decimal kilos)
    {
        var item = Carrito.FirstOrDefault(x => x.Id == producto.Id && x.TipoVenta == TipoVenta.Peso);

        if (item is null) {
            Carrito.Add(new CarritoItemDto {
                Id = producto.Id,
                Nombre = producto.Nombre,
                Cantidad = kilos,
                PrecioAplicado =producto.PrecioVenta.Value,
                TipoVenta = TipoVenta.Peso
            });
        } else {
            item.Cantidad += kilos;
        }
    }

    private void EliminarDelCarrito(int id)
    {
        var item = Carrito.FirstOrDefault(x => x.Id == id);
        if(item is not null){
            Carrito.Remove(item);
            item.Cantidad--;
        }
    }
    private MetodoDePago MetodoPagoSeleccionado = MetodoDePago.Efectivo;
    private async Task RealizarPago()
    {

        var venta = new VentaDto
        {
            MetodoPago = MetodoPagoSeleccionado,
            Observaciones = Observaciones,

            Detalles = Carrito.Select(x => new DetalleVentaDTO
            {
                ProductoID = x.Id,
                Cantidad = x.Cantidad,
                PrecioUnitario = x.PrecioUnitario ?? 0,
                TipoVenta = x.TipoVenta

            }).ToList()
        };

        var resultado = await VentaService.RealizarVenta(venta);

        if (resultado) {
            Carrito.Clear();
            Productos = await ProductoService.ObtenerTodos();
            MostrarModalPago = false;
        }
    }
    private bool PuedeAgregar(ProductoDTO producto)
    {
        var item = Carrito.FirstOrDefault(x => x.Id== producto.Id);

        if (item is null)
            return producto.StockActual > 0;

        return item.Cantidad < producto.StockActual;
    }

    private void LimpiarCarrito()
    {
        Carrito.Clear();
    }


    private void AbrirModalPago()
    {
        MostrarModalPago = true;
    }
    private void CerrarModal()
    {
        MostrarModalPago = false;
    }
    private DateTime? Desde;
    private DateTime? Hasta;
    private async Task ExportarVentasHoy()
    {
        Desde = DateTime.Today.AddHours(8);
        Hasta = DateTime.Today.AddHours(21);

        var pdf = await ReporteService.ExportarVentasPdf(Desde,Hasta);

        var base64 = Convert.ToBase64String(pdf);

        await JS.InvokeVoidAsync(
            "downloadFile",
            "ReporteVentas.pdf",
            "application/pdf",
            base64);
    }

    private int PaginaActual = 1;

    private async Task SiguientePagina()
    {
        PaginaActual++;
        Productos = await ProductoService.ObtenerTodos(PaginaActual);
    }

    private async Task PaginaAnterior()
    {
        if (PaginaActual > 1) {
            PaginaActual--;
            Productos = await ProductoService.ObtenerTodos(PaginaActual);
        }
    }

}
@page "/historial-ventas"

@using Panaderia.Blazor.Models
@using Panaderia.Shared.DTOs.Ventas
@using Panaderia.Blazor.Services

@inject VentaService VentaService
@inject ReporteService ReporteService
@inject IJSRuntime JS

<div class="row">
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2>
                <i class="bi bi-clock-history me-2"></i>
                Historial de Ventas
            </h2>

            <small class="text-muted">
                Consulta de ventas realizadas
            </small>
        </div>
        <button class="btn btn-outline-success"
                @onclick="AbrirModalReporte">

            <i class="bi bi-file-earmark-arrow-down me-2"></i>
            Reporte de ventas

        </button>

    </div>


    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header">

                <h5 class="mb-0">
                    <i class="bi bi-receipt me-2"></i>
                    Ventas Registradas
                </h5>

            </div>

            <div class="card-body p-0">

                @if (ventas is null) {
                    <div class="text-center p-4">

                        <div class="spinner-border text-primary"></div>

                        <p class="mt-3">
                            Cargando ventas...
                        </p>

                    </div>
                } else if (!ventas.Any()) {
                    <div class="text-center p-5 text-muted">

                        <i class="bi bi-inbox display-4"></i>

                        <p class="mt-3">
                            No existen ventas registradas
                        </p>

                    </div>
                } else {
                    <table class="table table-hover mb-0">

                        <thead class="table-light">

                            <tr>
                                <th>#</th>
                                <th>Fecha</th>
                                <th>Hora</th>
                                <th>Metodo pago</th>
                                <th>Total</th>
                                <th></th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var v in ventas) {
                                <tr>

                                    <td>
                                        <strong>@v.Id</strong>
                                    </td>

                                    <td>
                                        @v.Fecha.ToShortDateString()
                                    </td>

                                    <td>

                                        <span class="badge bg-secondary">
                                            @v.Fecha.ToShortTimeString()
                                        </span>

                                    </td>
                                    <td>
                                        @v.MetodoPago.ToString()
                                    </td>

                                    <td>

                                        <span class="fw-bold text-success">
                                            $ @v.Total
                                        </span>

                                    </td>

                                    <td>

                                        <button class="btn btn-outline-primary btn-sm"
                                                title="Ver detalle"
                                                @onclick="() => VerVenta(v.Id)">

                                            <i class="bi bi-eye-fill"></i>

                                        </button>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                }

            </div>

        </div>

    </div>
    <div class="col-lg-4">

        <div class="card shadow-sm sticky-top">

            <div class="card-header bg-primary text-white">

                <h5 class="mb-0">
                    <i class="bi bi-list-ul me-2"></i>
                    Detalle de Venta
                </h5>

            </div>

            <div class="card-body">

                @if (!Item.Any()) {
                    <div class="text-center text-muted py-5">

                        <i class="bi bi-search display-5"></i>

                        <p class="mt-3">
                            Seleccione una venta
                        </p>

                    </div>
                } else {
                    <table class="table">

                        <thead>

                            <tr>
                                <th>Producto</th>
                                <th>Cant.</th>
                                <th>Subtotal</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Item) {
                                <tr>

                                    <td>
                                        @item.Nombre
                                    </td>

                                    <td>

                                        <span class="badge bg-secondary">
                                            @item.Cantidad
                                        </span>

                                    </td>

                                    <td>
                                        $ @((item.Cantidad * item.PrecioVenta)?.ToString("N2"))
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                    <hr />

                    <div class="text-end">

                        <h5 class="text-success">

                            Total:
                            $ @Item.Sum(x => x.Cantidad * x.PrecioVenta)

                        </h5>

                    </div>
                }

            </div>

        </div>

    </div>
    <div class="d-flex justify-content-center align-items-center gap-2 mt-3">

        <button class="btn btn-outline-primary btn-sm"
                disabled="@(PaginaActual == 1)"
                @onclick="PaginaAnterior">

            <i class="bi bi-chevron-left"></i>

        </button>

        <span class="badge bg-primary fs-6 px-3 py-2">
            @PaginaActual
        </span>

        <button class="btn btn-outline-primary btn-sm"
                @onclick="SiguientePagina">
            <i class="bi bi-chevron-right"></i>

        </button>

    </div>

</div>
@if (MostrarModalReporte) {
    <div class="modal fade show d-block"
         tabindex="-1"
         style="background-color:rgba(0,0,0,.5);">

        <div class="modal-dialog">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">

                        <i class="bi bi-file-earmark-arrow-down me-2"></i>

                        Exportar Reporte

                    </h5>

                    <button class="btn-close"
                            @onclick="CerrarModalReporte">
                    </button>

                </div>

                <div class="modal-body">

                    <div class="alert alert-info">

                        <strong>Acceso rápido</strong>

                        <hr />

                        <button class="btn btn-success w-100"
                                @onclick="ExportarHoy">

                            <i class="bi bi-calendar-check me-2"></i>

                            Exportar ventas del día
                            <br />

                            <small>
                                08:00 hs - 21:00 hs
                            </small>

                        </button>

                    </div>

                    <hr />

                    <h6>Rango personalizado</h6>

                    <div class="row">

                        <div class="col-md-6">

                            <label>Desde</label>

                            <InputDate class="form-control"
                                       @bind-Value="FechaDesde" />

                        </div>

                        <div class="col-md-6">

                            <label>Hasta</label>

                            <InputDate class="form-control"
                                       @bind-Value="FechaHasta" />

                        </div>

                    </div>

                </div>

                <div class="modal-footer">

                    <button class="btn btn-secondary"
                            @onclick="CerrarModalReporte">

                        Cancelar

                    </button>

                    <button class="btn btn-danger"
                            @onclick="ExportarPdf">

                        <i class="bi bi-file-earmark-pdf me-2"></i>

                        PDF

                    </button>

                    <button class="btn btn-success"
                            @onclick="ExportarExcel">

                        <i class="bi bi-file-earmark-excel me-2"></i>

                        Excel

                    </button>

                </div>

            </div>

        </div>

    </div>
}




@code {
    private List<VentaHistorialDto>? ventas = new();
    private List<CarritoItemDto> Item = new();
    public decimal? Subtotal { get; set; }

    protected override async Task OnInitializedAsync()
    {
        ventas = await VentaService.HistorialVentas(1);
    }

    private void VerVenta(int id)
    {
        Item.Clear();
        var v = ventas.FirstOrDefault(x => x.Id == id);

        foreach (var item in v.Detalles) {
            Item.Add(new CarritoItemDto
            {
                Nombre = item.Producto,
                PrecioVenta = item.PrecioUnitario,
                Cantidad = item.Cantidad,

            });
            Subtotal = item.Subtotal;
        }
    }
    private int PaginaActual = 1;

    private async Task SiguientePagina()
    {
        PaginaActual++;
        ventas = await VentaService.HistorialVentas(PaginaActual);
    }

    private async Task PaginaAnterior()
    {
        if (PaginaActual > 1) {
            PaginaActual--;
            ventas = await VentaService.HistorialVentas(PaginaActual);
        }
    }
    private bool MostrarModalReporte;

    private void AbrirModalReporte()
    {
        MostrarModalReporte = true;
    }

    private void CerrarModalReporte()
    {
        MostrarModalReporte = false;
    }
    private DateTime? FechaDesde = DateTime.Today;
    private DateTime? FechaHasta = DateTime.Today;

    private async Task ExportarHoy()
    {
        FechaDesde = DateTime.Today.AddHours(8);
        FechaHasta = DateTime.Today.AddHours(21);
        var pdf = await ReporteService.ExportarVentasPdf(FechaDesde,FechaHasta);

        var base64 = Convert.ToBase64String(pdf);

        await JS.InvokeVoidAsync
        ("downloadFile",
          $"ReporteVentas_{FechaDesde:dd-MM-yyyy}_{FechaHasta:dd-MM-yyyy}.pdf",
          "application/pdf",
          base64);

    }

    
    private async Task ExportarPdf()
    {
        var desde = FechaDesde?.Date;

        var hasta = FechaHasta?.Date.AddHours(23).AddMinutes(59).AddSeconds(59);
        var pdf = await ReporteService.ExportarVentasPdf(desde, hasta);
        var base64 = Convert.ToBase64String(pdf);

        await JS.InvokeVoidAsync(
           "downloadFile",
           $"ReporteVentas_{FechaDesde:dd-MM-yyyy}_{FechaHasta:dd-MM-yyyy}.pdf",
           "application/pdf",
           base64);

        MostrarModalReporte = false;
    }
    private async Task ExportarExcel()
    {
        var desde = FechaDesde?.Date;

        var hasta = FechaHasta?.Date.AddHours(23).AddMinutes(59).AddSeconds(59);
        var excel = await ReporteService.ExportarVentasExcel(desde, hasta);
        var base64 = Convert.ToBase64String(excel);
        await JS.InvokeVoidAsync
        ("downloadFile",$"ReporteVentas_{FechaDesde:dd-MM-yyyy}_{FechaHasta:dd-MM-yyyy}.xlsx","application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",base64);

        MostrarModalReporte = false;
    }
}


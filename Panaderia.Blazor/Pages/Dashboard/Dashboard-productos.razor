@page "/dashboard/dashboard-productos"

@using ApexCharts
@using Panaderia.Shared.DTOs.Productos
@using Panaderia.Blazor.Services


@inject ProductoService DashboardService

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2>
                <i class="bi bi-bar-chart-fill me-2"></i>
                Dashboard de Productos
            </h2>

            <small class="text-muted">
                Top 10 productos más vendidos
            </small>
        </div>

    </div>

    <div class="row">

        <!-- TOP 10 -->

        <div class="col-lg-6">

            <div class="card shadow-sm">

                <div class="card-header bg-primary text-white">

                    <h5 class="mb-0">
                        <i class="bi bi-trophy-fill me-2"></i>
                        Top 10 Más Vendidos
                    </h5>

                </div>

                <div class="card-body">

                    <table class="table table-hover">

                        <thead>

                            <tr>
                                <th>#</th>
                                <th>Producto</th>
                                <th>Cantidad</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in ProductosMasVendidos.Select((p, i) => new { p, i })) {
                                <tr>

                                    <td>
                                        <span class="badge bg-primary">
                                            @(item.i + 1)
                                        </span>
                                    </td>

                                    <td>
                                        @item.p.Nombre
                                    </td>

                                    <td>
                                        <strong>
                                            @item.p.CantidadVendida
                                        </strong>
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- TORTA -->

        <div class="col-lg-6">

            <div class="card shadow-sm">

                <div class="card-header bg-success text-white">

                    <h5 class="mb-0">
                        <i class="bi bi-pie-chart-fill me-2"></i>
                        Distribución de Productos
                    </h5>

                </div>

                <div class="card-body">
                    @if (ProductosMasVendidos != null && ProductosMasVendidos.Any()) {
                        <ApexChart TItem="ProductoMasVendidoDto" Title="Productos mas vendidos">
                            <ApexPointSeries TItem="ProductoMasVendidoDto"
                                             Items="ProductosMasVendidos"
                                             Name="Productos"
                                             SeriesType="SeriesType.Pie"
                                             XValue="x => x.Nombre"
                                             YValue="x => x.CantidadVendida" />
                        </ApexChart>
                    } else {
                        <div class="text-center p-3">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando datos...</span>
                            </div>
                            <p class="mt-2 text-muted">Cargando gráfico...</p>
                        </div>
                    }
                </div>

            </div>

        </div>

    </div>

</div>

@code {

    private List<ProductoMasVendidoDto> ProductosMasVendidos = new();

    protected override async Task OnInitializedAsync()
    {
        ProductosMasVendidos = await DashboardService.ProductoMasVendido();
        StateHasChanged();
    }

}
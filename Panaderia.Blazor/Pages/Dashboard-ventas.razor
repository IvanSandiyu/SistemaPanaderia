@page "/dashboard/dashboard-ventas"

@using ApexCharts
@using Panaderia.Blazor.Models
@using Panaderia.Blazor.Services


@inject DashboardService DashboardService

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2>
                <i class="bi bi-bar-chart-fill me-2"></i>
                Dashboard de Ventas
            </h2>

            <small class="text-muted">
                Historial de ventas
            </small>
        </div>

    </div>

    <div class="row">

        <!-- TOP 10 -->

        <div class="col-lg-6">

            <div class="card shadow-sm">

                <div class="card-header bg-primary text-white">

                    <h5 class="mb-0">
                        <i class="bi bi-trophy-fill me-2"></i>
                        Historial de ventas
                    </h5>

                </div>

                <div class="card-body">

                    <table class="table table-hover">

                        <thead>

                            <tr>
                                <th>#</th>
                                <th>Fecha</th>
                                <th>Total</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in HistorialVentas.Select((v, i) => new { v, i })) {
                                <tr>

                                    <td>
                                        <span class="badge bg-primary">
                                            @(item.i + 1)
                                        </span>
                                    </td>

                                    <td>
                                        @item.v.Fecha.ToShortDateString()
                                    </td>

                                    <td>
                                        <strong>
                                            @item.v.Total
                                        </strong>
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- TORTA -->

        <div class="col-lg-6">

            <div class="card shadow-sm">

                <div class="card-header bg-success text-white">

                    <h5 class="mb-0">
                        <i class="bi bi-pie-chart-fill me-2"></i>
                        Distribución de Ventas
                    </h5>

                </div>

                <div class="card-body">
                    @* <p>Cantidad registros: @ProductosMasVendidos.Count</p> *@
                    <ApexChart TItem="VentaDiariaDto"
                               Title="Ventas">

                        <ApexPointSeries TItem="VentaDiariaDto"
                                         Items="HistorialVentas"
                                         Name="Ventas"
                                         XValue="x => x.Fecha.ToShortDateString()"
                                         YValue="x => x.Total" />

                    </ApexChart>

                </div>

            </div>

        </div>

    </div>

</div>

@code {

    private List<VentaDiariaDto> HistorialVentas = new();

    protected override async Task OnInitializedAsync()
    {

        HistorialVentas = await DashboardService.VentasPorDia();
        StateHasChanged();
    }

}
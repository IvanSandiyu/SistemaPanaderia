@page "/productos/nuevo"


@using Panaderia.Shared.DTOs.Productos
@using Panaderia.Blazor.Services
@using Panaderia.Shared.DTOs.Proveedores

@inject ProductoService ProductoService
@inject ProveedorService ProveedorService
@inject NavigationManager Navigation

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow-sm">

            <div class="card-header bg-success text-white">

                <h4 class="mb-0">

                    <i class="bi bi-plus-circle me-2"></i>

                    Nuevo Producto

                </h4>

            </div>

            <div class="card-body">

                <EditForm Model="Producto"
                          OnValidSubmit="Guardar">

                    <div class="row">

                        <div class="col-md-12 mb-3">

                            <label class="form-label">
                                Nombre
                            </label>

                            <InputText class="form-control"
                                       @bind-Value="Producto.Nombre" />

                        </div>
                        <div class="col-md-12 mb-3">

                            <label class="form-label">
                                Proveedor
                            </label>

                            <InputSelect class="form-select"
                                         @bind-Value="Producto.ProveedorId">

                                <option value="0">
                                    -- Seleccione un proveedor --
                                </option>

                                @foreach (var proveedor in listaProveedores) {
                                    <option value="@proveedor.Id">
                                        @proveedor.Nombre
                                    </option>
                                }

                            </InputSelect>

                        </div>


                        <!-- ===================== KG ===================== -->

                        <div class="col-12">

                            <h5 class="border-bottom pb-2 mb-3">

                                Venta por Kilogramo

                            </h5>

                        </div>


                        <div class="col-md-4 mb-3">

                            <label class="form-label">

                                Precio Compra Kg

                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="Producto.PrecioCompra" />

                        </div>


                        <div class="col-md-4 mb-3">

                            <label class="form-label">

                                % Ganancia Kg

                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="Producto.PorcentajeGanancia" />

                        </div>


                        <div class="col-md-4 mb-3">

                            <label class="form-label">

                                Precio Venta Kg

                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="Producto.PrecioVenta"
                                         disabled="@(Producto.PorcentajeGanancia > 0)" />

                        </div>


                        <div class="col-12 mb-4">

                            <div class="alert alert-info">

                                Precio sugerido Kg:

                                <strong>

                                    $ @PrecioVentaCalculado

                                </strong>

                            </div>

                        </div>


                        <!-- ===================== UNIDAD ===================== -->

                        <div class="col-12">

                            <h5 class="border-bottom pb-2 mb-3">

                                Venta por Unidad

                            </h5>

                        </div>


                        <div class="col-md-4 mb-3">

                            <label class="form-label">

                                Precio Compra Unidad

                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="Producto.PrecioCompraUnidad" />

                        </div>


                        <div class="col-md-4 mb-3">

                            <label class="form-label">

                                % Ganancia Unidad

                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="Producto.PorcentajeGananciaUnidad" />

                        </div>


                        <div class="col-md-4 mb-3">

                            <label class="form-label">

                                Precio Venta Unidad

                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="Producto.PrecioVentaUnidad"
                                         disabled="@(Producto.PorcentajeGananciaUnidad > 0)" />

                        </div>


                        <div class="col-12 mb-4">

                            <div class="alert alert-info">

                                Precio sugerido Unidad:

                                <strong>

                                    $ @PrecioVentaUnidadCalculado

                                </strong>

                            </div>

                        </div>


                        <!-- ===================== STOCK ===================== -->

                        <div class="col-md-6 mb-4">

                            <label class="form-label">

                                Stock Inicial

                            </label>

                            <InputNumber class="form-control"
                                         @bind-Value="Producto.StockActual" />

                        </div>

                    </div>


                    <hr />


                    <div class="d-flex justify-content-end gap-2">

                        <button type="button"
                                class="btn btn-secondary"
                                @onclick="Cancelar">

                            <i class="bi bi-x-circle me-2"></i>

                            Cancelar

                        </button>


                        <button type="submit"
                                class="btn btn-success">

                            <i class="bi bi-check-circle me-2"></i>

                            Crear Producto

                        </button>

                    </div>

                </EditForm>

            </div>

        </div>

    </div>

</div>

@code {

    private ProductoDTO Producto = new();
    private List<ProveedorDTO> listaProveedores = new();
    private ProveedorDTO Proveedor = new();
    private string Mensaje { get; set; }
    private bool MostrarMensaje { get; set; } = false;
    private decimal? PrecioVentaCalculado => Producto.PorcentajeGanancia > 0 ? Producto.PrecioCompra *(1 + Producto.PorcentajeGanancia / 100m): Producto.PrecioVenta;
    
    protected override async Task OnInitializedAsync()
    {
        listaProveedores = await ProveedorService.ObtenerTodos();
    }
    private async Task Guardar()
    {
        var creado = await ProductoService.CrearProducto(Producto);

        if (creado) {
            Mensaje = "Producto creado con éxito";
            MostrarMensaje = true;

            StateHasChanged();

            await Task.Delay(3000);
            Navigation.NavigateTo("/productos");
        }
    }
    // private decimal? PrecioVentaCalculado =>
    // Producto.PorcentajeGanancia > 0
    //     ? Producto.PrecioCompra.GetValueOrDefault()
    //       * (1 + Producto.PorcentajeGanancia.GetValueOrDefault() / 100)
    //     : Producto.PrecioVenta.GetValueOrDefault();

    private decimal? PrecioVentaUnidadCalculado =>
        Producto.PorcentajeGananciaUnidad > 0
            ? Producto.PrecioCompraUnidad.GetValueOrDefault()
              * (1 + Producto.PorcentajeGananciaUnidad.GetValueOrDefault() / 100)
            : Producto.PrecioVentaUnidad.GetValueOrDefault();

    private void Cancelar()
    {
        Navigation.NavigateTo("/productos");
    }
}
@page "/productos/editar/{Id:int}"

@using Panaderia.Shared.DTOs.Productos
@using Panaderia.Blazor.Services
@using Panaderia.Shared.DTOs.Proveedores

@inject ProductoService ProductoService
@inject ProveedorService ProveedorService
@inject NavigationManager Navigation

<div class="container">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-sm">

                <div class="card-header bg-primary text-white">

                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>
                        Editar Producto
                    </h4>

                </div>

                <div class="card-body">

                    @if (Producto is null) {
                        <div class="text-center p-4">

                            <div class="spinner-border text-primary"></div>

                            <p class="mt-3">
                                Cargando producto...
                            </p>

                        </div>
                    } else {
                        <div class="alert alert-info">
                            <strong>ID:</strong> @Producto.Id
                        </div>
                        <EditForm Model="Producto"
                                  OnValidSubmit="Guardar">

                            <div class="row">

                                <div class="col-md-12 mb-3">

                                    <label class="form-label">
                                        Nombre
                                    </label>

                                    <InputText class="form-control"
                                               @bind-Value="Producto.Nombre" />

                                </div>

                                <div class="col-md-12 mb-3">

                                    <label class="form-label">
                                        Proveedor
                                    </label>

                                    <InputSelect class="form-select"
                                                 @bind-Value="Producto.ProveedorId">

                                        <option value="0">
                                            -- Seleccione un proveedor --
                                        </option>

                                        @foreach (var proveedor in listaProveedores) {
                                            <option value="@proveedor.Id">
                                                @proveedor.Nombre
                                            </option>
                                        }

                                    </InputSelect>

                                </div>

                                <!-- ===================== POR KG ===================== -->

                                <div class="col-12">
                                    <h5 class="border-bottom pb-2 mb-3">
                                        Venta por Kilogramo
                                    </h5>
                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">
                                        Precio Compra Kg
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.PrecioCompra" />

                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">
                                        % Ganancia Kg
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.PorcentajeGanancia" />

                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">
                                        Precio Venta Kg
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.PrecioVenta"
                                                 disabled="@(Producto.PorcentajeGanancia > 0)" />

                                </div>

                                <div class="col-12 mb-4">

                                    <div class="alert alert-info">
                                        Precio sugerido Kg:
                                        <strong>$ @PrecioVentaCalculado</strong>
                                    </div>

                                </div>

                                <!-- ===================== POR UNIDAD ===================== -->

                                <div class="col-12">
                                    <h5 class="border-bottom pb-2 mb-3">
                                        Venta por Unidad
                                    </h5>
                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">
                                        Precio Compra Unidad
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.PrecioCompraUnidad" />

                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">
                                        % Ganancia Unidad
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.PorcentajeGananciaUnidad" />

                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">
                                        Precio Venta Unidad
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.PrecioVentaUnidad"
                                                 disabled="@(Producto.PorcentajeGananciaUnidad > 0)" />

                                </div>

                                <div class="col-12 mb-4">

                                    <div class="alert alert-info">
                                        Precio sugerido Unidad:
                                        <strong>$ @PrecioVentaUnidadCalculado</strong>
                                    </div>

                                </div>

                                <!-- ===================== STOCK ===================== -->

                                <div class="col-md-6 mb-4">

                                    <label class="form-label">
                                        Stock Actual
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.StockActual" />

                                </div>

                            </div>

                            <hr />

                            <div class="d-flex justify-content-end gap-2">

                                <button type="button"
                                        class="btn btn-secondary"
                                        @onclick="Cancelar">

                                    <i class="bi bi-x-circle me-2"></i>
                                    Cancelar

                                </button>

                                <button type="submit"
                                        class="btn btn-primary">

                                    <i class="bi bi-check-circle me-2"></i>
                                    Guardar Cambios

                                </button>

                            </div>

                        </EditForm>
                    }

                </div>

            </div>

        </div>

    </div>

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    public ProductoDTO Producto = new();
    private ProveedorDTO Proveedor = new();
    private List<ProveedorDTO> listaProveedores = new();
    private decimal? PrecioVentaCalculado => Producto.PorcentajeGanancia > 0 ? Producto.PrecioCompra * (1 + Producto.PorcentajeGanancia / 100m) : Producto.PrecioVenta;
    private decimal? PrecioVentaUnidadCalculado => Producto.PorcentajeGananciaUnidad > 0 ? Producto.PrecioCompraUnidad * (1 + Producto.PorcentajeGananciaUnidad.Value / 100): Producto.PrecioVentaUnidad;
    protected override async Task OnInitializedAsync()
    {
        Producto = await ProductoService.ObtenerPorId(Id);
        Proveedor = await ProveedorService.ObtenerPorId(Producto.ProveedorId);
        listaProveedores = await ProveedorService.ObtenerTodos();

    }

    private async Task Guardar()
    {
        var actualizado =
            await ProductoService.Actualizar(Producto.Id, Producto);

        if (actualizado) {
            Navigation.NavigateTo("/productos");
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/productos");
    }

}
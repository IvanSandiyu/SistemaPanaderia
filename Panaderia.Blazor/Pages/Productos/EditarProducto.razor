@page "/productos/editar/{Id:int}"
@using Panaderia.Blazor.Models
@using Panaderia.Blazor.Models.Productos
@using Panaderia.Blazor.Services

@inject ProductoService ProductoService
@inject NavigationManager Navigation

<div class="container">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-sm">

                <div class="card-header bg-primary text-white">

                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>
                        Editar Producto
                    </h4>

                </div>

                <div class="card-body">

                    @if (Producto is null) {
                        <div class="text-center p-4">

                            <div class="spinner-border text-primary"></div>

                            <p class="mt-3">
                                Cargando producto...
                            </p>

                        </div>
                    } else {
                        <div class="alert alert-info">
                            <strong>ID:</strong> @Producto.Id
                        </div>
                        <EditForm Model="Producto"
                                  OnValidSubmit="Guardar">

                            <div class="row">

                                <div class="col-md-12 mb-3">

                                    <label class="form-label">
                                        Nombre
                                    </label>

                                    <InputText class="form-control"
                                               @bind-Value="Producto.Nombre" />

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Precio Compra
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.PrecioCompra" />

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Precio Venta
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.PrecioVenta" />

                                </div>

                                <div class="col-md-6 mb-4">

                                    <label class="form-label">
                                        Stock Actual
                                    </label>

                                    <InputNumber class="form-control"
                                                 @bind-Value="Producto.StockActual" />

                                </div>

                            </div>

                            <hr />

                            <div class="d-flex justify-content-end gap-2">

                                <button type="button"
                                        class="btn btn-secondary"
                                        @onclick="Cancelar">

                                    <i class="bi bi-x-circle me-2"></i>
                                    Cancelar

                                </button>

                                <button type="submit"
                                        class="btn btn-primary">

                                    <i class="bi bi-check-circle me-2"></i>
                                    Guardar Cambios

                                </button>

                            </div>

                        </EditForm>
                    }

                </div>

            </div>

        </div>

    </div>

</div>

@code {

    [Parameter]
    public int Id { get; set; }

    public ProductoDto Producto = new();

    protected override async Task OnInitializedAsync()
    {
        Producto = await ProductoService.ObtenerPorId(Id);
    }

    private async Task Guardar()
    {
        var actualizado =
            await ProductoService.Actualizar(Producto.Id, Producto);

        if (actualizado) {
            Navigation.NavigateTo("/productos");
        }
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/productos");
    }

}
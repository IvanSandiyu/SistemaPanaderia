@page "/productos"
@using Panaderia.Shared.DTOs.Productos
@using Panaderia.Blazor.Services
@using Panaderia.Shared.DTOs.Reportes

@inject ProductoService ProductoService
@inject ReporteService ReporteService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="mb-0">
                <i class="bi bi-box-seam-fill me-2"></i>
                Productos
            </h2>

            <small class="text-muted">
                Gestión de productos y stock
            </small>
        </div>

        <div class="d-flex gap-2">

            <button class="btn btn-outline-success"
                    @onclick="AbrirModalReporte">

                <i class="bi bi-file-earmark-arrow-down me-2"></i>
                Exportar

            </button>

            <button class="btn btn-primary"
                    @onclick="Crear">

                <i class="bi bi-plus-circle me-2"></i>
                Nuevo Producto

            </button>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            @if (ProductosFiltrados is null) {
                <div class="text-center p-4">
                    <div class="spinner-border text-primary"></div>

                    <p class="mt-3">
                        Cargando productos...
                    </p>

                </div>

            } else {
                <div class="card-header">

                    <div class="d-flex justify-content-between align-items-center">

                        <h5 class="mb-0">

                            <i class="bi bi-box-seam-fill me-2"></i>

                            Productos

                        </h5>

                        <div style="width:300px">

                            <input class="form-control form-control-sm"
                                   placeholder="🔎 Buscar producto..."
                                   @bind="Busqueda"
                                   @bind:event="oninput" />

                        </div>

                    </div>

                </div>
                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>ID</th>
                                <th>Producto</th>
                                <th>Precio Compra</th>
                                <th>Precio Venta</th>
                                <th>Precio Venta Unidad</th>
                                <th>Stock</th>
                                @* <th>Porcentaje Ganancias</th> *@
                                <th width="120">Acciones</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var producto in ProductosFiltrados) {
                                <tr>

                                    <td>
                                        @producto.Id
                                    </td>

                                    <td>
                                         @producto.Nombre
                                    </td>

                                    <td>
                                        $ @producto.PrecioCompra
                                    </td>

                                    <td>
                                        $ @producto.PrecioVenta
                                    </td>
                                    <td>
                                        $ @producto.PrecioVentaUnidad
                                    </td>

                                    <td>

                                        @if (producto.StockActual <= 0) {
                                            <span class="badge bg-danger">
                                                Sin Stock
                                            </span>
                                        } else if (producto.StockActual <= 10) {
                                            <span class="badge bg-warning text-dark">
                                                @producto.StockActual
                                            </span>
                                        } else {
                                            <span class="badge bg-success">
                                                @producto.StockActual
                                            </span>
                                        }

                                    </td>

                                   @*  <td>
                                         @producto.PorcentajeGanancia %
                                    </td> *@

                                    <td>

                                        <button class="btn btn-outline-primary btn-sm"
                                                title="Editar"
                                                @onclick="() => EditarProducto(producto.Id)">

                                            <i class="bi bi-pencil-square"></i>

                                        </button>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>

    </div>

</div>
@if (MostrarModalReporte) {
    <div class="modal fade show d-block"
         tabindex="-1"
         style="background-color:rgba(0,0,0,.5);">

        <div class="modal-dialog">

            <div class="modal-content">

                <div class="modal-header">

                    <h5 class="modal-title">

                        <i class="bi bi-file-earmark-arrow-down me-2"></i>

                        Exportar Reporte

                    </h5>

                    <button class="btn-close"
                            @onclick="CerrarModalReporte">
                    </button>

                </div>

                <div class="modal-body">

                    <div class="alert alert-info">

                        <strong>Acceso rápido</strong>

                        <hr />

                        <button class="btn btn-success w-100"
                                @onclick="ExportarHoy">

                            <i class="bi bi-calendar-check me-2"></i>

                            Exportar ventas del día
                            <br />

                            <small>
                                08:00 hs - 21:00 hs
                            </small>

                        </button>

                    </div>

                   @*  <hr />

                    <h6>Rango personalizado</h6>

                    <div class="row">

                        <div class="col-md-6">

                            <label>Desde</label>

                            <InputDate class="form-control"
                                       @bind-Value="FechaDesde" />

                        </div>

                        <div class="col-md-6">

                            <label>Hasta</label>

                            <InputDate class="form-control"
                                       @bind-Value="FechaHasta" />

                        </div>

                    </div> *@

                </div>

                @* <div class="modal-footer">

                    <button class="btn btn-secondary"
                            @onclick="CerrarModalReporte">

                        Cancelar

                    </button>

                    <button class="btn btn-danger"
                            @onclick="ExportarPdf">

                        <i class="bi bi-file-earmark-pdf me-2"></i>

                        PDF

                    </button>

                    <button class="btn btn-success"
                            @onclick="ExportarExcel">

                        <i class="bi bi-file-earmark-excel me-2"></i>

                        Excel

                    </button>

                </div> *@

            </div>

        </div>

    </div>
}

@code {

    private List<ProductoDTO>? productos;

    protected override async Task OnInitializedAsync()
    {
        productos = await ProductoService.ObtenerTodos();
    }

    private void EditarProducto(int id)
    {
        Navigation.NavigateTo($"/productos/editar/{id}");
    }

    private void Crear()
    {
        Navigation.NavigateTo("/productos/nuevo");
    }

    private bool MostrarModalReporte;

    // private DateTime? FechaDesde = DateTime.Today;

    // private DateTime? FechaHasta = DateTime.Today;

    private void AbrirModalReporte()
    {
        MostrarModalReporte = true;
    }

    private void CerrarModalReporte()
    {
        MostrarModalReporte = false;
    }

    private async Task ExportarHoy()
    {
        var pdf = await ReporteService.ExportarProductosPdf();

        var base64 = Convert.ToBase64String(pdf);

        await JS.InvokeVoidAsync(
            "downloadFile",
            "ReporteProductos.pdf",
            "application/pdf",
            base64);

    }
    // private async Task ExportarPdf()
    // {
    //     var desde = FechaDesde?.Date;

    //     var hasta = FechaHasta?.Date.AddHours(23).AddMinutes(59).AddSeconds(59);

    //     //Llamar al endpoint PDF

    //     MostrarModalReporte = false;
    // }
    // private async Task ExportarExcel()
    // {
    //     var desde = FechaDesde?.Date;

    //     var hasta = FechaHasta?.Date.AddHours(23).AddMinutes(59).AddSeconds(59);

    //     //Llamar al endpoint Excel

    //     MostrarModalReporte = false;
    // }
   


    private string Busqueda = "";

    private IEnumerable<ProductoDTO> ProductosFiltrados =>
     string.IsNullOrWhiteSpace(Busqueda)
         ? productos ?? Enumerable.Empty<ProductoDTO>()
         : (productos ?? Enumerable.Empty<ProductoDTO>())
             .Where(x => x.Nombre.Contains(Busqueda, StringComparison.OrdinalIgnoreCase));
}
@using Microsoft.AspNetCore.Components

<div class="sidebar-menu">

    <button class="btn btn-outline-light w-100 mb-4"
            @onclick="Toggle">
        <i class="bi bi-list"></i>
    </button>

    <nav class="nav flex-column">

        <NavLink class="nav-link"
                 href="/"
                 Match="NavLinkMatch.All">

            <i class="bi bi-house-door-fill"></i>

            @if (!Contraido) {
                <span class="ms-2">Inicio</span>
            }

        </NavLink>

        <NavLink class="nav-link"
                 href="/productos">

            <i class="bi bi-box-seam-fill"></i>

            @if (!Contraido) {
                <span class="ms-2">Productos</span>
            }

        </NavLink>

        <NavLink class="nav-link"
                 href="/ventas">

            <i class="bi bi-cart-check-fill"></i>

            @if (!Contraido) {
                <span class="ms-2">Ventas</span>
            }

        </NavLink>

        <NavLink class="nav-link"
                 href="/historial-ventas">

            <i class="bi bi-clock-history"></i>

            @if (!Contraido) {
                <span class="ms-2">Historial</span>
            }

        </NavLink>

        <NavLink class="nav-link" href="/dashboard">

            <i class="bi bi-bar-chart"></i>

            @if (!Contraido) {
                <span class="ms-2">Metricas</span>
            }
        </NavLink>

    </nav>

</div>

@code {

    [Parameter]
    public bool Contraido { get; set; }

    [Parameter]
    public EventCallback OnToggle { get; set; }

    private async Task Toggle()
    {
        await OnToggle.InvokeAsync();
    }

}